{
	"name": "Rust",
	"image": "mcr.microsoft.com/devcontainers/rust:1-1-bookworm",
	"features": {
		"ghcr.io/devcontainers-contrib/features/apt-packages:1": {
			"packages": "cmake,ninja-build,protobuf-compiler,libprotoc-dev"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"zxh404.vscode-proto3"
			]
		}
	},
	"postCreateCommand": "mkdir -p ~/.local/bin && curl -L https://github.com/protocolbuffers/protobuf/releases/download/v26.1/protoc-26.1-linux-x86_64.zip -o /tmp/protoc.zip && sudo unzip -o -d /usr/local /tmp/protoc.zip"
}
